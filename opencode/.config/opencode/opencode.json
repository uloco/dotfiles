{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "plugin": ["opencode-claude-auth@latest"],
  "permission": {
    "external_directory": {
      "~/.dotfiles/nvim/*": "allow",
      "~/.local/share/nvim/*": "allow",
      "~/Source/neovim/bluloco.nvim/*": "allow",
      "/opt/homebrew/Cellar/neovim/*": "allow"
    }
  },
  "mcp": {
    "atlassian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://mcp.atlassian.com/v1/sse"
      ],
      "enabled": false
    },
    "gitlab": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote@latest",
        "https://gitlab.boxine.de/api/v4/mcp"
      ],
      "enabled": false
    },
    "configcat": {
      "type": "local",
      "command": ["npx", "-y", "@configcat/mcp-server"],
      "enabled": false
    }
  },
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "eu-central-1",
        "profile": "experimental"
      }
    }
  }
}
